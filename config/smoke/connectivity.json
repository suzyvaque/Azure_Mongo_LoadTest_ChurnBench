  "Dataset": {
    "DocumentCount": 40,
    "Seed": 42,
    "Buckets": [
      { "Name": "Small",  "SizeBytes": 6144,  "Count": 10 },
      { "Name": "Medium", "SizeBytes": 16384, "Count": 10 },
      { "Name": "Large",  "SizeBytes": 51200, "Count": 10 },
      { "Name": "XL",     "SizeBytes": 59392, "Count": 10 }
    ]
  },
  "Seeder": {
    "InsertBatchSize": 20,
    "CosmosInsertBatchSize": 10,
    "DeleteBatchSize": 50
