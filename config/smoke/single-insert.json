{
  // Smoke-test config: single-op insert-output, 30 s, 1 iteration.
  // Isolates cold-connection write cost (insert into calc_output, no prior remove).
  // Note: accumulates docs in calc_output — intended only for short targeted tests.
  // Produces only insert latency in the result (find_input/remove/find_output are absent).
  "TaskSleepMs": 0,
  "Dataset": {
    "DocumentCount": 40,
    "Seed": 42,
    "Buckets": [
      { "Name": "Small",  "SizeBytes": 6144,  "Count": 10 },
      { "Name": "Medium", "SizeBytes": 16384, "Count": 10 },
      { "Name": "Large",  "SizeBytes": 51200, "Count": 10 },
      { "Name": "XL",     "SizeBytes": 59392, "Count": 10 }
    ]
  },
  "Seeder": {
    "InsertBatchSize": 20,
    "CosmosInsertBatchSize": 10,
    "DeleteBatchSize": 50
  },
  "Scenario": {
    "Iterations": 1,
    "IterationDurationSeconds": 30,
    "MaxConcurrentTasks": 200,
    "ResourceSampleIntervalMs": 1000,
    "Steady": { "Enabled": true, "TasksPerSecond": 10, "DurationSeconds": 30 },
    "Burst": { "Enabled": false, "JobsPerSecondLambda": 0.57, "MaxTasksPerJob": 5, "MinTasksPerJob": 1, "DurationSeconds": 30 }
  },
  "Workload": {
    "Mode": "SingleOp",
    "SingleOpType": "InsertOutput"
  }
}
