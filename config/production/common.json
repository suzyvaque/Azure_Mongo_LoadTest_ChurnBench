{
  // COMMON production config — shared by all config/production/*.json via "Extends": "common.json".
  // Holds the canonical scenario envelope + dataset/seeder/preflight/client settings so each per-test
  // config only overrides what differs (TaskSleepMs + Workload). Child configs deep-merge OVER this
  // file: repeat any key in a child to override it (scalars/arrays replace; nested objects merge).
  //
  // Secrets are NOT stored here — connection strings are read at runtime from env vars:
  //   cosmos-ru -> BMT_CONN_COSMOS,  documentdb -> BMT_CONN,  mongo-vm -> BMT_CONN_MONGO,
  //   mongo-shard -> BMT_CONN_MONGO_SHARD

  // Per-Task calc-time substitute sleep, in ms (test_instruction.md §6.6). Full-workload uses 2 s;
  // single-op configs override this to 0.
  "TaskSleepMs": 2000,

  // Dataset: exactly 100,000 docs, fixed seed 42, four whole-document size buckets.
  "Dataset": {
    "DocumentCount": 100000,
    "Seed": 42,
    "Buckets": [
      { "Name": "Small",  "SizeBytes": 6144,  "Count": 10000 },
      { "Name": "Medium", "SizeBytes": 16384, "Count": 15000 },
      { "Name": "Large",  "SizeBytes": 51200, "Count": 35000 },
      { "Name": "XL",     "SizeBytes": 59392, "Count": 40000 }
    ]
  },

  // Seeder tuning. Cosmos uses smaller insert batches to ease RU throttling; RU/s is never changed.
  "Seeder": {
    "InsertBatchSize": 1000,
    "CosmosInsertBatchSize": 100,
    "DeleteBatchSize": 500
  },

  // Scenario envelope (test_instruction.md §6.2).
  // IMPORTANT: a scenario runs only when its own "Enabled" flag is true AND the CLI --scenario
  // selects it. Keep Steady and Burst SEPARATE by enabling just one at a time — running both at once
  // STACKS their arrival rates (~2x the measured production peak; see analysis).
  //   * Burst-only (default below): the Poisson burst already reproduces the full peak envelope
  //     (≈135 conn/s average + the 1,200 conn/s instantaneous spikes). Nothing is added on top.
  //   * Steady-only: set Steady.Enabled=true and Burst.Enabled=false for the smooth peak-hour case.
  "Scenario": {
    "Iterations": 3,
    "IterationDurationSeconds": 300,
    "MaxConcurrentTasks": 15000,
    "ResourceSampleIntervalMs": 1000,
    "Steady": {
      "Enabled": false,
      "TasksPerSecond": 135,
      "DurationSeconds": 300
    },
    "Burst": {
      "Enabled": true,
      "JobsPerSecondLambda": 0.57,
      "MaxTasksPerJob": 500,
      "MinTasksPerJob": 14,
      "DurationSeconds": 300,
      // Open-loop mode: when true, the (seed-deterministic) Poisson arrival schedule is injected
      // WITHOUT the MaxConcurrentTasks back-pressure gate, so the realized conn/sec equals the
      // offered schedule identically for every target regardless of backend speed. This makes the
      // burst a controlled INPUT (fair cross-target comparison) instead of a closed-loop OUTPUT.
      // Closed-loop (false, default) keeps the gate so the client host cannot grow sockets unbounded.
      "OpenLoop": false
    }
  },

  // Per-Task MongoClient tuning (applied uniformly; does NOT relax the no-reuse model).
  "Client": {
    "ServerSelectionTimeoutMs": 5000,
    "ConnectTimeoutMs": 5000,
    "SocketTimeoutMs": 0,
    "DirectConnectionForSingleNode": true
  },

  // Preflight gate (§6.3).
  "Preflight": {
    "ResultsDirectory": "artifacts",
    "MinFreeDiskBytes": 1073741824,
    "ConcurrentConnectionTarget": 11000,
    "ConnectionChurnPerSecTarget": 1200,
    "RequirePrivateNetwork": true,
    "SampleSize": 1000,
    "WarmupMaxAgeMinutes": 360,
    "CosmosExpectedRuPerSec": 100000,
    "DocumentDbExpectedTier": "M80",
    "MongoExpectedMaxIncomingConnections": null
  }
}
