{
  // PRODUCTION config — full 4-op workload (find-input -> remove-output -> insert-output -> find-output).
  // This is the canonical benchmark run. Inherits the scenario/dataset/seeder/preflight/client envelope
  // from common.json; only the workload + calc-time sleep differ here.
  //
  // Scenario selection (Steady vs Burst) lives in common.json via the per-scenario "Enabled" flags
  // — enable just one at a time to keep them separate. Override here only if this run needs to differ.
  "Extends": "common.json",

  // Per-Task calc-time substitute sleep, in ms (test_instruction.md §6.6).
  "TaskSleepMs": 10000,

  // Full 4-op cycle per connection (SingleOpType is ignored when Mode=FullWorkload).
  "Workload": {
    "Mode": "FullWorkload",
    "SingleOpType": "FindInput"
  }
}
